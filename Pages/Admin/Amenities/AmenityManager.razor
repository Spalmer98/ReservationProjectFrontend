@page "/admin/amenitymanager"

@inject AmenityService AmenityService
@inject NotificationService NotificationService

<h1>Amenity Manager</h1>

<div class="mt-4">
    <h3>Quick Actions</h3>
    <div class="btn-group" role="group">
        <NavLink class="btn btn-primary" href="admin">Dashboard</NavLink>
        <NavLink class="btn btn-primary" href="admin/usermanager">Manage Users</NavLink>
        <NavLink class="btn btn-primary" href="admin/roommanager">Manage Rooms</NavLink>
        <NavLink class="btn btn-primary" href="admin/reservationmanager">Manage Reservations</NavLink>
        <NavLink class="btn btn-primary" href="admin/amenitymanager" ActiveClass="active">Manage Amenities</NavLink>
    </div>
</div>

@if (!string.IsNullOrEmpty(NotificationService.SuccessMessage))
{
    <div class="alert alert-success">
        @NotificationService.SuccessMessage
    </div>
}

<div class="mt-4">
    <h3>Manage Amenities</h3>
    <div class="btn-group" role="group">
        <NavLink class="btn btn-primary" href="admin/amenitymanager/addamenity">Add Amenity</NavLink>
    </div>
    <!-- Example: Display a list of amenities -->
    <table class="table">
        <thead>
            <tr>
                <th>Amenity Name</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <!-- Loop through amenities and display them here -->
            @foreach (var amenity in Amenities)
            {
                <tr>
                    <td>@amenity.Name</td>
                    <td>@amenity.Description</td>
                    <td>
                        <!-- Add buttons for editing and deleting amenities -->
                        <button class="btn btn-sm btn-primary">Edit</button>
                        <button class="btn btn-sm btn-danger">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {

    private List<AmenitySelectionDto> Amenities { get; set; } = new List<AmenitySelectionDto>();
    

    protected override async Task OnInitializedAsync()
    {
        // Fetch the list of amenities from the service
        Amenities = await AmenityService.GetAmenitiesAsync();
    }
}