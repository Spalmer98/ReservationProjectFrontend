@page "/reservation-calendar"
@using System.Net
@using System.Net.Http.Json
@using CSE325project.Shared
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Reservation Calendar</PageTitle>

<h1>Reservation Calendar</h1>

@if (loading)
{
    <p>Loading room calendar...</p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <p class="calendar-error">@errorMessage</p>
}
else
{
    <div class="calendar-controls">
        <label>
            Room
            <select value="@selectedRoomId" @onchange="RoomChanged">
                @foreach (var room in rooms)
                {
                    <option value="@room.RoomId">@room.RoomName</option>
                }
            </select>
        </label>

        <div>
            <button @onclick="PreviousWeek">Previous</button>
            <button @onclick="CurrentWeek">This Week</button>
            <button @onclick="NextWeek">Next</button>
        </div>
    </div>

    @if (SelectedRoom is not null)
    {
        <h2>Room @SelectedRoom.RoomName</h2>
        <p>@SelectedRoom.Location - Capacity: @SelectedRoom.Capacity</p>
        <p><strong>@weekStart.ToString("MMMM d") - @weekStart.AddDays(4).ToString("MMMM d, yyyy")</strong></p>

        @if (!isLoggedIn)
        {
            <p class="calendar-note">
                Log in to reserve an appointment.
                <a href="/login">Login</a>
            </p>
        }
        else if (!string.IsNullOrWhiteSpace(saveMessage))
        {
            <p class="calendar-note">@saveMessage</p>
        }

        <div class="calendar-preview">
            @foreach (var day in WeekDays)
            {
                <div>
                    <strong>@day.ToString("dddd")</strong>
                    <span>@day.ToString("MMM d")</span>

                    @foreach (var slot in SlotsFor(day))
                    {
                        <button class="slot-button @(slot.IsAvailable ? "available" : "reserved")"
                            disabled="@(!slot.IsAvailable || saving || !isLoggedIn)"
                            @onclick="() => ReserveSlot(slot)">
                            @slot.StartTime.ToString("h:mm tt") - @slot.EndTime.ToString("h:mm tt")
                        </button>
                    }
                </div>
            }
        </div>
    }
}

<a class="button-link secondary" href="/floor-plan">Back to Floor Plan</a>

@code {
    [SupplyParameterFromQuery]
    public string? Room { get; set; }

    private List<Room> rooms = new();
    private List<AppointmentSlot> slots = new();
    private long selectedRoomId;
    private DateOnly weekStart = StartOfWeek(DateOnly.FromDateTime(DateTime.Today));
    private bool loading = true;
    private bool saving;
    private bool isLoggedIn;
    private string errorMessage = "";
    private string saveMessage = "";

    private Room? SelectedRoom =>
        rooms.FirstOrDefault(room => room.RoomId == selectedRoomId);

    private IEnumerable<DateOnly> WeekDays =>
        Enumerable.Range(0, 5).Select(day => weekStart.AddDays(day));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            isLoggedIn = authState.User.Identity?.IsAuthenticated == true;

            rooms = await Http.GetFromJsonAsync<List<Room>>("api/Rooms") ?? new();

            var requestedRoom = rooms.FirstOrDefault(room =>
                room.RoomName.Equals(Room, StringComparison.OrdinalIgnoreCase));

            selectedRoomId = requestedRoom?.RoomId ?? rooms.FirstOrDefault()?.RoomId ?? 0;

            await LoadSlots();
        }
        catch (HttpRequestException)
        {
            errorMessage = "Start the server project to load rooms and reservations.";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task RoomChanged(ChangeEventArgs args)
    {
        if (long.TryParse(args.Value?.ToString(), out var roomId))
        {
            selectedRoomId = roomId;
            saveMessage = "";
            await LoadSlots();
        }
    }

    private async Task LoadSlots()
    {
        if (selectedRoomId == 0)
        {
            slots = new();
            return;
        }

        var start = weekStart.ToDateTime(TimeOnly.MinValue).ToString("yyyy-MM-dd");
        slots = await Http.GetFromJsonAsync<List<AppointmentSlot>>(
            $"api/Reservation/slots?roomId={selectedRoomId}&weekStart={start}") ?? new();
    }

    private async Task ReserveSlot(AppointmentSlot slot)
    {
        if (!isLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        if (!slot.IsAvailable || saving)
        {
            return;
        }

        saving = true;
        saveMessage = "";

        var reservation = new Reservation
        {
            RoomId = slot.RoomId,
            StartTime = slot.StartTime,
            EndTime = slot.EndTime,
            Status = "Reserved"
        };

        var response = await Http.PostAsJsonAsync("api/Reservation", reservation);

        if (response.IsSuccessStatusCode)
        {
            saveMessage = "Reservation saved.";
            await LoadSlots();
        }
        else if (response.StatusCode == HttpStatusCode.Unauthorized)
        {
            isLoggedIn = false;
            saveMessage = "Log in to reserve an appointment.";
        }
        else if (response.StatusCode == HttpStatusCode.Conflict)
        {
            saveMessage = "That time is already reserved.";
            await LoadSlots();
        }
        else
        {
            saveMessage = "Could not save that reservation.";
        }

        saving = false;
    }




    private List<AppointmentSlot> SlotsFor(DateOnly day)
    {
        return slots
            .Where(slot => DateOnly.FromDateTime(slot.StartTime) == day)
            .OrderBy(slot => slot.StartTime)
            .ToList();
    }

    private async Task PreviousWeek()
    {
        weekStart = weekStart.AddDays(-7);
        saveMessage = "";
        await LoadSlots();
    }

    private async Task NextWeek()
    {
        weekStart = weekStart.AddDays(7);
        saveMessage = "";
        await LoadSlots();
    }

    private async Task CurrentWeek()
    {
        weekStart = StartOfWeek(DateOnly.FromDateTime(DateTime.Today));
        saveMessage = "";
        await LoadSlots();
    }

    private static DateOnly StartOfWeek(DateOnly date)
    {
        var daysSinceMonday = ((int)date.DayOfWeek + 6) % 7;
        return date.AddDays(-daysSinceMonday);
    }
}
